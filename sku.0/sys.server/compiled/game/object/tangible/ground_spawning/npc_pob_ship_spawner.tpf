// NPC POB ship spawner - spawns Sorosuub shuttle, cycles Naboo city waypoints

@base object/tangible/base/tangible_base.iff

@class tangible_object_template 0

@class object_template 5

sharedTemplate = "object/tangible/ground_spawning/shared_npc_pob_ship_spawner.iff"

scripts = +["space.npc_pob_ship_spawner"]

visibleFlags = [ VF_gm ]

invulnerable = true
